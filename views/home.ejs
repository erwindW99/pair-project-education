<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Home</title>
</head>

<body>
  <h1>Welcome to the Home Page</h1>

  <% if (notif) { %>
  <div class="alert alert-success">
    <%= notif %>
  </div>
  <% } %>

  <%- include("header") %>

  <form method="get" action="/home">
    <input type="text" name="search" placeholder="Search your course by name" />
    <button type="submit">Search</button>
  </form>

  <a href="/courses/add">Add New Course</a>
  <table border="1">
    <thead>
      <tr>
        <th>Course Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Code</th>
        <th>Category</th>
        <th>Total</th>
        <th>Actions</th>
      </tr>
    </thead>

    <% data.forEach(el => { %>
    <tr>
      <td><%= el.name %></td>
      <td><%= el.description %></td>
      <td><%= formattedCurrency(el.price) %></td>
      <td><%= el.code %></td>
      <td><%= el.category %></td>
      <td><%= el.Materials.length %></td>
      <td>
        <a href="/courses/<%= el.id %>/materials">Detail Course</a>
        <a href="/courses/<%= el.id %>/edit">Edit</a>
        <a href="/courses/<%= el.id %>/learn" onclick="return confirm('Are you sure you want to enroll in this course?')">
          Learn Course
        </a>
      </td>
    </tr>
    <% }) %>
  </table>

 <canvas id="progressChart" width="600" height="300"></canvas>

<script src="/static/chart.umd.js"></script>

<script id="chart-data" type="application/json">
<%- JSON.stringify({ labels: chartLabels || [], data: chartData || [] }) %>
</script>

<script>
  const chartVars = JSON.parse(document.getElementById('chart-data').textContent);
  const ctx = document.getElementById('progressChart').getContext('2d');
  const progressChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: chartVars.labels,
      datasets: [{
        label: 'Course Progress (%)',
        data: chartVars.data,
        backgroundColor: 'rgba(54, 162, 235, 0.5)',
        borderColor: 'rgba(54, 162, 235, 1)',
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        y: { beginAtZero: true, max: 100 }
      }
    }
  });
</script>

  <%- include("footer") %>
</body>

</html>