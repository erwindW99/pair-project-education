<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/footer.css" />
  <link rel="stylesheet" href="/css/home.css" />
  <title>Home</title>
</head>

<body>
  <%- include("header") %>

  <main>
    <form method="get" action="/home">
      <input type="text" name="search" placeholder="Search your course by name" />
      <button type="submit">Search</button>
      <% if (role === 'Teacher') { %>
      <a href="/courses/add" class="add-course-btn">Add New Course</a>
      <% } %>
    </form>

    <% if (notif) { %>
    <div class="alert alert-success"><%= notif %></div>
    <% } %>

    <div class="course-grid">
      <% data.forEach(el => { %>
      <div class="course-card">
        <h2><%= el.name %></h2>
        <div class="course-info"><strong>Category:</strong> <%= el.category %></div>
        <div class="course-info"><strong>Code:</strong> <%= el.code %></div>
        <div class="course-info course-desc"><strong>Description:</strong> <%= el.description %></div>
        <div class="course-stats">
          <span><strong>Price:</strong> <%= formattedCurrency(el.price) %></span>
          <span><strong>Materials:</strong> <%= el.Materials.length %></span>
        </div>
        <div class="actions">
          <% if (role === 'Student') { %>
          <% if (!learnIds.includes(el.id)) { %>
          <a href="/courses/<%= el.id %>/learn" class="btn-learn" onclick="return confirm('Are you sure you want to enroll in this course?')">Learn Course</a>
          <% } else { %>
          <a href="/courses/<%= el.id %>/materials" class="btn-detail">Detail Course</a>
          <% } %>
          <% } else if (role === 'Teacher') { %>
          <a href="/courses/<%= el.id %>/materials" >Detail Course</a>
          <a href="/courses/<%= el.id %>/edit">Edit</a>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>

    <% if (role === 'Student') { %>
    <div class="chart-section">
      <h3 class="chart-title">Your Course Progress</h3>
      <canvas id="progressChart" width="600" height="300"></canvas>
    </div>
    <script src="/static/chart.umd.js"></script>
    <script id="chart-data" type="application/json">
      <%- JSON.stringify({ labels: chartLabels || [], data: chartData || [] }) %>
    </script>
    <script>
      const chartVars = JSON.parse(document.getElementById('chart-data').textContent);
      const ctx = document.getElementById('progressChart').getContext('2d');
      const progressChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: chartVars.labels,
          datasets: [{
            label: 'Course Progress (%)',
            data: chartVars.data,
            backgroundColor: [
              'rgba(86, 36, 208, 0.22)',
              'rgba(252, 163, 17, 0.22)',
              'rgba(86, 36, 208, 0.22)',
              'rgba(252, 163, 17, 0.22)',
            ],
            borderColor: [
              'rgba(86, 36, 208, 1)',
              'rgba(252, 163, 17, 1)',
              'rgba(86, 36, 208, 1)',
              'rgba(252, 163, 17, 1)',
            ],
            borderWidth: 2
          }]
        },
        options: {
          scales: {
            y: {
              beginAtZero: true,
              max: 100
            }
          }
        }
      });
    </script>
    <% } %>
  </main>

  <%- include("footer") %>
</body>

</html>